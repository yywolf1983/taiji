<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#303F9F" android:endColor="#1A237E" android:angle="90"/>
            <stroke android:width="1dp" android:color="#5C6BC0"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#1A237E" android:endColor="#0D1442" android:angle="90"/>
            <stroke android:width="1dp" android:color="#3949AB"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
