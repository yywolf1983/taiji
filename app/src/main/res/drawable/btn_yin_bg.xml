<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#3D4B66" android:endColor="#2A354F" android:angle="90"/>
            <stroke android:width="1dp" android:color="#6B7DA0"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#243045" android:endColor="#182033" android:angle="90"/>
            <stroke android:width="1dp" android:color="#4A5B7A"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
