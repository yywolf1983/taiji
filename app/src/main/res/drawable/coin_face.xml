<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#C9A45C"/>
            <stroke android:width="3dp" android:color="#9A7B2E"/>
            <gradient
                android:type="radial"
                android:startColor="#D4B87A"
                android:endColor="#9A7B2E"
                android:gradientRadius="40dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#9A7B2E"/>
            <size android:width="50dp" android:height="50dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#9A7B2E"/>
            <size android:width="30dp" android:height="30dp"/>
        </shape>
    </item>
</layer-list>
