<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#B8943E" android:endColor="#9A7B2E" android:angle="90"/>
            <stroke android:width="1dp" android:color="#D4B87A"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#9A7B2E" android:endColor="#7A611F" android:angle="90"/>
            <stroke android:width="1dp" android:color="#C9A45C"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
