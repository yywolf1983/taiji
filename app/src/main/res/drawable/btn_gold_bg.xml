<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#DAA520" android:endColor="#B8860B" android:angle="90"/>
            <stroke android:width="1dp" android:color="#FFD700"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#B8860B" android:endColor="#8B6914" android:angle="90"/>
            <stroke android:width="1dp" android:color="#DAA520"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
