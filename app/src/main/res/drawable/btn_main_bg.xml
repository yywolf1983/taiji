<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#3D3D3D" android:endColor="#2A2A2A" android:angle="90"/>
            <stroke android:width="2dp" android:color="#6A6A6A"/>
            <corners android:radius="12dp"/>
            <padding android:left="20dp" android:top="14dp" android:right="20dp" android:bottom="14dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#2D2D2D" android:endColor="#1A1A1A" android:angle="90"/>
            <stroke android:width="2dp" android:color="#4A4A4A"/>
            <corners android:radius="12dp"/>
            <padding android:left="20dp" android:top="14dp" android:right="20dp" android:bottom="14dp"/>
        </shape>
    </item>
</selector>