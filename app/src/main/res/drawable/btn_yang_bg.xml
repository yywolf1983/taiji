<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#8B6508" android:endColor="#6B4E06" android:angle="90"/>
            <stroke android:width="1dp" android:color="#DAA520"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#6B4E06" android:endColor="#4A3604" android:angle="90"/>
            <stroke android:width="1dp" android:color="#B8860B"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
