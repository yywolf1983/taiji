<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#2A2D38" android:endColor="#1E202B" android:angle="90"/>
            <stroke android:width="1dp" android:color="#3D4150"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#1E202B" android:endColor="#14161E" android:angle="90"/>
            <stroke android:width="1dp" android:color="#2D3345"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
