<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_gradient"
    android:clipToPadding="false"
    android:scrollbars="vertical">

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/cardBackground80">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/nameTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/ChineseTitleStyle"
                                android:textSize="36sp"
                                android:textColor="@color/textPrimary" />

                            <TextView
                                android:id="@+id/pinyinTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/ChineseBodyStyle"
                                android:textSize="14sp"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="4dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">

                                <TextView
                                    android:id="@+id/natureTag"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:background="@drawable/tag_bg"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/wuxingTag"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:background="@drawable/tag_bg"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/familyTag"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="10sp"
                                    android:textColor="@color/textSecondary"
                                    android:background="@drawable/tag_bg"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="3dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <top.nones.app.HexagramView
                            android:id="@+id/guaView"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dividerColor60"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/guaTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/ChineseCaptionStyle"
                        android:textSize="12sp"
                        android:textColor="@color/textHint"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:id="@+id/summaryTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/ChineseBodyStyle"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary80"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:textStyle="italic" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground60">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/colorAccent"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            style="@style/SectionTitleStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="卦辞"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/judgmentTextView"
                        style="@style/ChineseBodyStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/textPrimary"
                        android:lineSpacingExtra="4sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground60">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/warningColor"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            style="@style/SectionTitleStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="爻辞详解"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/linesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground60">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/colorPrimaryLight"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            style="@style/SectionTitleStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="白话翻译"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/baihuaTextView"
                        style="@style/ChineseBodyStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/cardBackground60">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/successColor"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            style="@style/SectionTitleStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="现代解读"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/modernTextView"
                        style="@style/ChineseBodyStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dividerColor60"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/cardBackgroundElevated80"
                        android:padding="12dp"
                        android:layout_margin="-8dp"
                        android:layout_marginTop="0dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡 启示建议"
                            android:textSize="12sp"
                            android:textColor="@color/textHint"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/adviceTextView"
                            style="@style/ChineseBodyStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/cardBackground60">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/yangColor"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="2dp" />

                        <TextView
                            style="@style/SectionTitleStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="卦象属性"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="6">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="卦性" />

                            <TextView
                                android:id="@+id/natureDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="五行" />

                            <TextView
                                android:id="@+id/wuxingDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="家庭" />

                            <TextView
                                android:id="@+id/familyDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="季节" />

                            <TextView
                                android:id="@+id/seasonTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="方位" />

                            <TextView
                                android:id="@+id/directionTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/textHint"
                                android:text="卦数" />

                            <TextView
                                android:id="@+id/numberDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textColor="@color/textPrimary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>