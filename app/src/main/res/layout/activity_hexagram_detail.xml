<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_gradient">

    <ImageView
        android:id="@+id/decorTopLeft"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/decor_diagonal"
        android:alpha="0.3"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/decorTopRight"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/decor_diagonal"
        android:alpha="0.3"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/decorBottomLeft"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/decor_diagonal"
        android:alpha="0.3"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/decorBottomRight"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/decor_diagonal"
        android:alpha="0.3"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/cardBackground80">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/nameTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/ChineseTitleStyle"
                                    android:textSize="36sp"
                                    android:textColor="@color/textPrimary" />

                                <TextView
                                    android:id="@+id/pinyinTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/ChineseBodyStyle"
                                    android:textSize="14sp"
                                    android:textColor="@color/textSecondary"
                                    android:layout_marginTop="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center"
                                    android:layout_marginTop="8dp">

                                    <TextView
                                        android:id="@+id/natureTag"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="10sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/tag_bg"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="3dp"
                                        android:layout_marginEnd="6dp" />

                                    <TextView
                                        android:id="@+id/wuxingTag"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="10sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/tag_bg"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="3dp"
                                        android:layout_marginEnd="6dp" />

                                    <TextView
                                        android:id="@+id/familyTag"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="10sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/tag_bg"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="3dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <top.nones.app.HexagramView
                                android:id="@+id/guaView"
                                android:layout_width="90dp"
                                android:layout_height="wrap_content" />

                            <LinearLayout
                                android:id="@+id/changeButtonsLayout"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginTop="8dp">

                                <TextView
                                    android:id="@+id/changeHint"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="点击按钮变爻"
                                    android:textSize="11sp"
                                    android:textColor="@color/textHint"
                                    android:gravity="center"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="4dp" />

                                <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:layout_marginTop="4dp">

                                    <Button
                                        android:id="@+id/btnLine1"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp"
                                        android:layout_marginEnd="6dp" />
                                    <Button
                                        android:id="@+id/btnLine2"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp"
                                        android:layout_marginEnd="6dp" />
                                    <Button
                                        android:id="@+id/btnLine3"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp" />
                                </LinearLayout>

                                <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:layout_marginTop="4dp">

                                    <Button
                                        android:id="@+id/btnLine4"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp"
                                        android:layout_marginEnd="6dp" />
                                    <Button
                                        android:id="@+id/btnLine5"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp"
                                        android:layout_marginEnd="6dp" />
                                    <Button
                                        android:id="@+id/btnLine6"
                                        android:layout_width="48dp"
                                        android:layout_height="28dp"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary"
                                        android:background="@drawable/btn_line_normal"
                                        android:padding="0dp" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/decor_bagua"
                                android:layout_marginTop="8dp"
                                android:layout_gravity="center_horizontal" />
                        </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/dividerColor60"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <View
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/decor_cloud" />

                            <TextView
                                android:id="@+id/guaTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                style="@style/ChineseCaptionStyle"
                                android:textSize="12sp"
                                android:textColor="@color/textHint"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp" />

                            <View
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/decor_cloud" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/summaryTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ChineseBodyStyle"
                            android:textSize="13sp"
                            android:textColor="@color/textSecondary80"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="8dp"
                            android:textStyle="italic" />

                        <LinearLayout
                            android:id="@+id/zhiguaContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:background="@color/cardBackgroundElevated80"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">

                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="16dp"
                                    android:background="@color/warningColor"
                                    android:layout_marginEnd="8dp"
                                    android:layout_marginTop="2dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="之卦（变卦）"
                                    android:textSize="14sp"
                                    android:textColor="@color/textPrimary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="center">

                                    <top.nones.app.HexagramView
                                        android:id="@+id/zhiguaView"
                                        android:layout_width="70dp"
                                        android:layout_height="wrap_content" />

                                    <TextView
                                        android:id="@+id/zhiguaName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="16sp"
                                        android:textColor="@color/textPrimary"
                                        android:layout_marginTop="4dp"
                                        style="@style/ChineseTitleStyle" />

                                    <TextView
                                        android:id="@+id/zhiguaPinyin"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="@color/textSecondary" />
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="60dp"
                                    android:background="@color/dividerColor60"
                                    android:layout_marginStart="16dp"
                                    android:layout_marginEnd="16dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/zhiguaJudgment"
                                        style="@style/ChineseBodyStyle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textSize="13sp"
                                        android:textColor="@color/textSecondary"
                                        android:lineSpacingExtra="4sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/dividerColor60"
                                android:layout_marginTop="12dp"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/changeRuleExplain"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary80"
                                android:gravity="center"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="1dp"
                        android:background="@color/decorColor" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/decor_cloud_ornament"
                        android:alpha="0.5"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="1dp"
                        android:background="@color/decorColor" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/cardBackground60">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="16dp"
                                android:background="@color/colorAccent"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                style="@style/SectionTitleStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="卦辞"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/judgmentTextView"
                            style="@style/ChineseBodyStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/textPrimary"
                            android:lineSpacingExtra="4sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/cardBackground60">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="16dp"
                                android:background="@color/warningColor"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                style="@style/SectionTitleStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="爻辞详解"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/linesContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/decor_cloud_ornament"
                        android:alpha="0.5" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="1dp"
                        android:background="@color/decorColor"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/decor_cloud_ornament"
                        android:alpha="0.5" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/cardBackground60">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="16dp"
                                android:background="@color/colorPrimaryLight"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                style="@style/SectionTitleStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="白话翻译"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/baihuaTextView"
                            style="@style/ChineseBodyStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/cardBackground60">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="16dp"
                                android:background="@color/successColor"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                style="@style/SectionTitleStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="现代解读"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/modernTextView"
                            style="@style/ChineseBodyStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/dividerColor60"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@color/cardBackgroundElevated80"
                            android:padding="12dp"
                            android:layout_margin="-8dp"
                            android:layout_marginTop="0dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💡 启示建议"
                                android:textSize="12sp"
                                android:textColor="@color/textHint"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/adviceTextView"
                                style="@style/ChineseBodyStyle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/textPrimary"
                                android:textSize="14sp"
                                android:lineSpacingExtra="4sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="1dp"
                        android:background="@color/decorColor" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/decor_cloud_ornament"
                        android:alpha="0.5"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <View
                        android:layout_width="32dp"
                        android:layout_height="1dp"
                        android:background="@color/decorColor" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/cardBackground60">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="3dp"
                                android:layout_height="16dp"
                                android:background="@color/yangColor"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="2dp" />

                            <TextView
                                style="@style/SectionTitleStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="卦象属性"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="6">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="11sp"
                                    android:textColor="@color/textHint"
                                    android:text="卦性" />

                                <TextView
                                    android:id="@+id/natureDisplay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="15sp"
                                    android:textColor="@color/textPrimary"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center_horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
