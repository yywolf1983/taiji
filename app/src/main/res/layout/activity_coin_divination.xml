<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="铜钱占卜"
            android:textSize="22sp"
        android:textColor="@color/yangColor"
        android:textAlignment="center"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/guideCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/guideTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="准备工作"
                android:textSize="17sp"
                android:textColor="@color/goldGradientStart"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/guideText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请准备三枚铜钱，心中默念您想询问的问题。"
                android:textSize="14sp"
                android:textColor="@color/textHint"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selectionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/stepInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请选择投掷结果"
                android:textSize="15sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btn3Yang"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="3阳 (○○○) - 老阳"
                    android:textSize="14sp"
                    android:textColor="@color/yangColor"
                    android:background="@drawable/btn_yang_bg"
                    android:layout_marginBottom="6dp"/>

                <Button
                    android:id="@+id/btn2Yang1Yin"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="2阳1阴 (○○●) - 少阳"
                    android:textSize="14sp"
                    android:textColor="@color/goldGradientStart"
                    android:background="@drawable/btn_dark_bg"
                    android:layout_marginBottom="6dp"/>

                <Button
                    android:id="@+id/btn1Yang2Yin"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="1阳2阴 (○●●) - 少阴"
                    android:textSize="14sp"
                    android:textColor="@color/yinColor"
                    android:background="@drawable/btn_dark_bg"
                    android:layout_marginBottom="6dp"/>

                <Button
                    android:id="@+id/btn3Yin"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="3阴 (●●●) - 老阴"
                    android:textSize="14sp"
                    android:textColor="@color/yinColor"
                    android:background="@drawable/btn_yin_bg"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已选爻位"
                android:textSize="14sp"
                android:textColor="@color/textHint"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/linesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hexagramContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:visibility="gone"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/hexagramClickArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/clickable_bg"
                android:padding="16dp">

                <top.nones.app.HexagramView
                    android:id="@+id/resultHexagram"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/resultName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="34sp"
                    android:textColor="@color/yangColor"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/resultPinyin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/yinColor"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/resultGuaType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/resultGuaNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/textHint"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击查看详解 ▸"
                    android:textSize="12sp"
                    android:textColor="@color/goldGradientStart"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="开始占卜"
            android:textSize="16sp"
            android:textColor="@color/yangColor"
            android:background="@drawable/btn_gold_bg"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="32dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="重新占卜"
            android:textSize="16sp"
            android:textColor="@color/textHint"
            android:background="@drawable/btn_dark_bg"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="32dp"
            android:visibility="gone"/>
    </LinearLayout>
</ScrollView>