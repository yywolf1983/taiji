<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <top.nones.app.TaichiView
            android:id="@+id/taichiView"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="40dp">

            <Button
                android:id="@+id/btnCoinDivination"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="铜钱占卜"
                android:textSize="16sp"
                android:textColor="@color/yangColor"
                android:background="@drawable/btn_main_bg"
                android:layout_marginEnd="12dp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnYarrowDivination"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="蓍草占卜"
                android:textSize="16sp"
                android:textColor="@color/yinColor"
                android:background="@drawable/btn_main_bg"
                android:layout_marginStart="12dp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击按钮开始占卜"
            android:textSize="12sp"
            android:textColor="@color/textHint"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>