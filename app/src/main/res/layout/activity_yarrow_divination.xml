<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="蓍草占卜"
            android:textSize="22sp"
        android:textColor="#FFD700"
        android:textAlignment="center"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/guideCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/guideTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="准备工作"
                android:textSize="17sp"
                android:textColor="#DAA520"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/guideText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请准备49根蓍草或牙签，心中默念您想询问的问题。"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selectionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/stepInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请选择余数"
                android:textSize="15sp"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnRemainder1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="余数1"
                    android:textSize="14sp"
                    android:textColor="#FFD700"
                    android:background="@drawable/btn_yang_bg"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRemainder2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="余数2"
                    android:textSize="14sp"
                    android:textColor="#DAA520"
                    android:background="@drawable/btn_dark_bg"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="2"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnRemainder3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="余数3"
                    android:textSize="14sp"
                    android:textColor="#7986CB"
                    android:background="@drawable/btn_dark_bg"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRemainder4"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="余数4"
                    android:textSize="14sp"
                    android:textColor="#5C6BC0"
                    android:background="@drawable/btn_yin_bg"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已选爻位"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/linesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hexagramContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:visibility="gone"
            android:paddingBottom="12dp">

            <LinearLayout
                android:id="@+id/hexagramClickArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/clickable_bg"
                android:padding="16dp">

                <top.nones.app.HexagramView
                    android:id="@+id/resultHexagram"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/resultName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="34sp"
                    android:textColor="#FFD700"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/resultPinyin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#7986CB"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/resultGuaType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/resultGuaNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击查看详解 ▸"
                    android:textSize="12sp"
                    android:textColor="#DAA520"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="开始占卜"
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:background="@drawable/btn_gold_bg"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="32dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnRestart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="重新占卜"
            android:textSize="16sp"
            android:textColor="#888888"
            android:background="@drawable/btn_dark_bg"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="32dp"
            android:visibility="gone"/>
    </LinearLayout>
</ScrollView>